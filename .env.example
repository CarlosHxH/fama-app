# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new `.env` file when you clone the repo.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# NextAuth — obrigatório em produção; necessário para o middleware (JWT) validar sessões
# npx auth secret
AUTH_SECRET=""

# Prisma — o utilizador/palavra-passe devem coincidir com o PostgreSQL local ou Docker
# Erro "Authentication failed ... postgres are not valid" = credenciais erradas ou serviço parado
DATABASE_URL="postgresql://postgres:password@localhost:5432/fama-app"
# Em Docker, o host costuma ser `postgres` em vez de `localhost`.

# Asaas (cobrança PIX) — chave só no servidor
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://api.asaas.com/v3
ASAAS_API_KEY=""
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
# Token igual ao configurado no painel Asaas para o header `asaas-access-token` no webhook
ASAAS_WEBHOOK_TOKEN=""

# Login / marca (opcional — textos na página /login)
# NEXT_PUBLIC_APP_NAME="Central Financeira"
# NEXT_PUBLIC_ORG_FOOTER="Portal de cobrança"
# NEXT_PUBLIC_SUPPORT_PHONE="(00) 0000-0000"
# NEXT_PUBLIC_SUPPORT_WHATSAPP="5511999999999"

# Cobrança /cobranca (opcional)
# NEXT_PUBLIC_COBRANCA_HEADER_BADGE="Área do titular"
# NEXT_PUBLIC_COBRANCA_LEGAL_URL="https://exemplo.gov.br/legislacao"
# NEXT_PUBLIC_COBRANCA_LEGAL_TEXT="Texto curto sobre a base legal aplicável à cobrança."

# Seed: npm run db:seed — login só com CPF (11) ou CNPJ (14 dígitos), sem palavra-passe
# CPF de exemplo (sandbox): 24971563792
# SEED_ADMIN_CPF_CNPJ="24971563792"
# Email opcional (ex.: Asaas): SEED_ADMIN_EMAIL="admin@exemplo.com"
