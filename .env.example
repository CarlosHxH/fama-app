# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new `.env` file when you clone the repo.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# NextAuth — obrigatório em produção; necessário para o middleware (JWT) validar sessões
# npx auth secret
AUTH_SECRET=""

# Prisma — utilizador/palavra-passe iguais ao serviço Postgres que estiver a usar
# Se tiver PostgreSQL instalado no Windows na porta 5432, o Docker Compose deste projeto
# publica o Postgres do contentor em 5433 — use 127.0.0.1:5433 para o Prisma na máquina host.
# Erro P1000 em localhost:5432 costuma ser o Postgres nativo (outra palavra-passe), não o Docker.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/fama-app"
# Volume antigo pode ter criado a base como `famaapp`; nesse caso troque o nome no URL ou recrie o volume.
# Dentro da rede Docker (serviço `app`), o host é `postgres` e a porta interna 5432.

# Asaas (cobrança PIX) — chave só no servidor
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://api.asaas.com/v3
ASAAS_API_KEY=""
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
# Token igual ao configurado no painel Asaas para o header `asaas-access-token` no webhook
ASAAS_WEBHOOK_TOKEN=""

# Login / marca (opcional — textos na página /login)
# NEXT_PUBLIC_APP_NAME="Central Financeira"
# NEXT_PUBLIC_ORG_FOOTER="Portal de cobrança"
# NEXT_PUBLIC_SUPPORT_PHONE="(00) 0000-0000"
# NEXT_PUBLIC_SUPPORT_WHATSAPP="5511999999999"

# Cobrança /cobranca (opcional)
# NEXT_PUBLIC_COBRANCA_HEADER_BADGE="Área do titular"
# NEXT_PUBLIC_COBRANCA_LEGAL_URL="https://exemplo.gov.br/legislacao"
# NEXT_PUBLIC_COBRANCA_LEGAL_TEXT="Texto curto sobre a base legal aplicável à cobrança."

# Seed: npm run db:seed — titular com CPF/CNPJ em /login (sem palavra-passe); admin opcionalmente com senha em /admin/login
# Cria admin + titular USER + cobranças de teste + post (idempotente).
# SEED_ONLY_ADMIN=1 — só cria/atualiza o admin
# SEED_ADMIN_CPF_CNPJ="24971563792"
# SEED_ADMIN_EMAIL="admin@exemplo.com"
# Palavra-passe do admin para /admin/login (e-mail + senha). Se definida e SEED_ADMIN_EMAIL vazio, o seed usa admin@seed.local
# SEED_ADMIN_PASSWORD="altere_em_producao"
# SEED_TITULAR_CPF_CNPJ="52998224725"
# SEED_TITULAR_EMAIL="titular@exemplo.com"

# --- Job: npm run job:sync-sqlserver (SQL Server → Postgres) ---
# Pré-requisito: túnel VPN (ou rota) até o SQL Server; OpenVPN com management (ver config.ovpn).
# O script não inicia o binário openvpn — só liga a Postgres e ao MSSQL.
#
# Obrigatório: uma das opções
# MSSQL_CONNECTION_STRING="mssql://user:pass@host:1433/dbname?encrypt=true&trustServerCertificate=true"
# ou:
# MSSQL_SERVER="10.0.0.5"
# MSSQL_DATABASE="MinhaBase"
# MSSQL_USER="sync_user"
# MSSQL_PASSWORD="secret"
#
# TLS (Azure / encrypt obrigatório)
# MSSQL_ENCRYPT="true"
# MSSQL_TRUST_SERVER_CERTIFICATE="true"
#
# Healthcheck TCP antes do pool (recomendado após VPN; porta 1433 por defeito)
# SQL_SYNC_SKIP_HEALTHCHECK="false"
# MSSQL_HEALTHCHECK_HOST="10.0.0.5"
# MSSQL_HEALTHCHECK_PORT="1433"
#
# Progresso: log a cada N linhas sincronizadas (0 = só início/fim por tabela)
# SQL_SYNC_BATCH_SIZE="500"
# SQL_SYNC_MAX_RETRIES="12"
# SQL_SYNC_RETRY_DELAY_MS="2000"
#
# Mapeamento sem editar código (query T-SQL com coluna de chave; gravado em MssqlSyncRecord)
# MSSQL_SYNC_DEMO_QUERY="SELECT TOP 100 id, nome FROM dbo.Exemplo"
# MSSQL_SYNC_DEMO_SOURCE_TABLE="dbo.Exemplo"
# MSSQL_SYNC_DEMO_KEY_COLUMN="id"
#
# Datas legadas: Boletos / Cessionarios_Planos usam INT YYYYMMDD; o job acrescenta campos
# *_as_isodate no JSON (ver src/jobs/sqlserver-sync/legacy-dates.ts).

# Cron (Vercel ou outro): GET /api/cron/sync-sqlserver com header Authorization: Bearer <segredo>
# Defina o mesmo valor em Vercel → Cron → variável CRON_SECRET (ver vercel.json).
# CRON_SECRET=""

# Admin: perfil em PostgreSQL (coluna User.adminStaffRole): SUPER_ADMIN | FINANCEIRO | OPERACIONAL | VIEWER
# FINANCEIRO/SUPER_ADMIN podem emitir cobranças; OPERACIONAL/SUPER_ADMIN editam contactos; VIEWER só leitura.
