// =============================================================================
// schema.prisma — Portal do Cessionário (Cemitério)
// Banco: PostgreSQL 17+
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN
  FINANCEIRO
  ATENDENTE
}

enum TipoTelefone {
  CELULAR
  FIXO
  WHATSAPP
}

enum TipoEndereco {
  RESIDENCIAL
  COMERCIAL
}

enum SituacaoContrato {
  ATIVO    // A — sincronizado do SQL Server
  INATIVO  // I
  QUITADO  // Q
}

enum StatusPagamento {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
  ESTORNADO
}

enum TipoPagamento {
  MANUTENCAO
  AQUISICAO
  TAXA_SERVICO
}

enum MetodoPagamento {
  PIX
  BOLETO
  CARTAO_CREDITO
  CARTAO_DEBITO
}

enum TipoAlteracao {
  ENDERECO
  TELEFONE
  EMAIL
  DADOS_PESSOAIS
}

enum StatusAlteracao {
  PENDENTE
  APROVADA
  REJEITADA
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
  SMS
}

enum StatusNotificacao {
  ENVIADA
  ENTREGUE
  FALHA
}

enum SyncStatus {
  PROCESSANDO
  SUCESSO
  FALHA
}

// =============================================================================
// 1. USUÁRIOS DO DASHBOARD (Funcionários)
// =============================================================================

/// Funcionários com acesso ao dashboard administrativo.
/// Autenticação própria via JWT — independente do portal do cliente.
model User {
  id    String  @id @default(uuid())
  email String  @unique @db.VarChar(120)
  nome  String  @db.VarChar(160)
  senha String  // bcrypt hash
  role  Role    @default(ATENDENTE)
  ativo Boolean @default(true)

  changeRequests ChangeRequest[] @relation("ReviewedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("users")
}

// =============================================================================
// 2. CLIENTES (Cessionários — sincronizados do SQL Server)
// =============================================================================

/// Cessionário unificado. sql_server_id = CodCessionario original.
/// O CPF/CNPJ é o identificador de login no portal (apenas dígitos, sem máscara).
/// Pessoa física: 11 dígitos | Pessoa jurídica: 14 dígitos.
///
/// Fluxo de primeiro acesso:
///   1. Cliente informa CPF/CNPJ → sistema localiza o registro
///   2. primeiroAcesso = true → força criação de senha
///   3. senhaHash preenchido → primeiroAcesso = false → acesso liberado
///
/// Bloqueio por tentativas:
///   Após N tentativas erradas, bloqueadoAte é preenchido.
///   O portal rejeita login enquanto now() < bloqueadoAte.
///
/// Integração Asaas:
///   asaasCustomerId é preenchido na primeira cobrança gerada pelo portal.
///   Sem este campo, cada nova cobrança criaria um cliente duplicado no Asaas.
///
/// Responsável financeiro por jazigo (cobrança):
///   Quem paga a manutenção de um jazigo pode ser outro registo em `customers` (FK opcional em
///   `Jazigos.responsavel_financeiro_customer_id`). Um mesmo `Customer` pode ser titular de uns
///   contratos e pagador noutros jazigos — dados sempre centralizados nesta tabela (CPF único,
///   índices existentes, um JOIN por linha na listagem).
model Customer {
  id             String    @id @default(uuid())
  sqlServerId    Int?      @unique @map("sql_server_id") // CodCessionario — nulo até o primeiro sync
  cpfCnpj        String    @unique @map("cpf_cnpj") @db.VarChar(14) // apenas dígitos, sem máscara — login principal
  nome           String    @db.VarChar(160)
  email          String?   @db.VarChar(120)
  senhaHash      String?   @map("senha_hash")            // nulo até o primeiro acesso
  primeiroAcesso Boolean   @default(true)  @map("primeiro_acesso")
  ativo          Boolean   @default(true)

  // Segurança de login
  tentativasLogin Int       @default(0)  @map("tentativas_login")
  bloqueadoAte    DateTime? @map("bloqueado_ate")

  // Integração Asaas
  asaasCustomerId String?   @unique @map("asaas_customer_id") @db.VarChar(50)

  // Controle de sync
  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  enderecos     CustomerAddress[]
  telefones     CustomerPhone[]
  refreshTokens CustomerRefreshToken[]
  contratos     Contrato[]
  pagamentos    Pagamento[]
  notificacoes  Notificacao[]
  changeRequests ChangeRequest[]

  /// Jazigos em que este `Customer` é o pagador designado (independente de ser titular do contrato).
  jazigosOndeResponsavelFinanceiro Jazigo[] @relation("JazigoResponsavelFinanceiro")

  @@index([cpfCnpj])
  @@index([email])
  @@map("customers")
}

// -----------------------------------------
// 2a. Endereços
// -----------------------------------------

/// Endereços do cessionário sincronizados do SQL Server.
/// correspondencia = true indica o endereço usado para envio de boleto físico.
/// O Asaas exige pelo menos logradouro, cidade e UF para gerar cobranças.
model CustomerAddress {
  id              String       @id @default(uuid())
  sqlServerId     Int?         @unique @map("sql_server_id")
  customerId      String       @map("customer_id")
  tipo            TipoEndereco @default(RESIDENCIAL)
  logradouro      String?      @db.VarChar(200)
  numero          String?      @db.VarChar(10)
  complemento     String?      @db.VarChar(100)
  bairro          String?      @db.VarChar(100)
  cidade          String?      @db.VarChar(120)
  uf              String?      @db.Char(2)
  cep             String?      @db.VarChar(10)
  correspondencia Boolean      @default(false) // endereço principal para envio de boleto

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([customerId])
  @@map("customer_addresses")
}

// -----------------------------------------
// 2b. Telefones
// -----------------------------------------

/// Telefones do cessionário — pode ter múltiplos por tipo.
model CustomerPhone {
  id         String       @id @default(uuid())
  sqlServerId Int?         @unique @map("sql_server_id")
  customerId String       @map("customer_id")
  tipo       TipoTelefone
  numero     String       @db.VarChar(20)
  /// Notas internas sobre este contacto (ex.: horário, quem atende).
  observacoes String?     @db.Text @map("observacoes")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([customerId])
  @@map("customer_phones")
}

// -----------------------------------------
// 2c. Refresh Tokens do Portal
// -----------------------------------------

/// Controla sessões ativas do portal do cliente.
/// Permite revogar acesso imediatamente em caso de troca de senha
/// ou suspeita de acesso indevido — sem depender da expiração do JWT.
///
/// Job de limpeza recomendado:
///   DELETE FROM customer_refresh_tokens
///   WHERE expires_at < now() OR revogado = true
model CustomerRefreshToken {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  token      String   @unique
  expiresAt  DateTime @map("expires_at")
  revogado   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt]) // índice para o job de limpeza de tokens expirados
  @@map("customer_refresh_tokens")
}

// =============================================================================
// 3. CORE: CONTRATOS E JAZIGOS (sincronizados do SQL Server)
// =============================================================================

/// Contrato de concessão de jazigo. sql_server_id = CodContrato original.
model Contrato {
  id             String           @id @default(uuid())
  sqlServerId    Int?             @unique @map("sql_server_id")
  numeroContrato String           @unique @map("numero_contrato") @db.VarChar(30)
  situacao       SituacaoContrato @default(ATIVO)

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  jazigos               Jazigo[]
  pagamentos            Pagamento[]            // atalho direto — evita join duplo em consultas financeiras
  responsavelFinanceiro ResponsavelFinanceiro?

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([customerId])
  @@map("contratos")
}

// -----------------------------------------
// 3a. Responsável Financeiro
// -----------------------------------------

/// Responsável financeiro do contrato quando diferente do cessionário titular.
/// Exemplo: filho que paga a manutenção do jazigo do pai.
///
/// Vínculo 1:1 com Contrato — cada contrato tem no máximo um responsável financeiro.
/// As cobranças no Asaas devem ser geradas em nome deste responsável, não do cessionário.
model ResponsavelFinanceiro {
  id         String  @id @default(uuid())
  contratoId String  @unique @map("contrato_id")
  nome       String  @db.VarChar(160)
  cpf        String  @db.VarChar(14)
  email      String? @db.VarChar(120)
  telefone   String? @db.VarChar(20)
  motivo     String? @db.Text // justificativa do vínculo (ex: "Filho responsável pelo pagamento")

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("responsaveis_financeiros")
}

// -----------------------------------------
// 3b. Jazigos
// -----------------------------------------

/// Jazigo concedido. sql_server_id = CodJazigo original.
///
/// valorMensalidade é fixado no momento do sync com base no Decreto 4.332/2023:
///   3 gavetas → R$ 180,00/mês | 6 gavetas → R$ 360,00/mês
///
/// IMPORTANTE: não altere valorMensalidade diretamente em produção após um reajuste
/// tarifário. O snapshot histórico fica em Pagamento (gavetasNaEpoca / valorNaEpoca),
/// que preserva o valor vigente no momento de cada emissão.
model Jazigo {
  id                String  @id @default(uuid())
  sqlServerId       Int?    @unique @map("sql_server_id")
  codigo            String  @unique @db.VarChar(20)
  quadra            String? @db.VarChar(20)
  setor             String? @db.VarChar(20)

  // Decreto 4.332/2023
  quantidadeGavetas Int     @default(3)        @map("quantidade_gavetas")
  valorMensalidade  Decimal @db.Decimal(10, 2) @map("valor_mensalidade")

  contratoId String   @map("contrato_id")
  contrato   Contrato @relation(fields: [contratoId], references: [id])

  /// Opcional: outro registo em `customers` que paga a manutenção deste jazigo (Asaas).
  /// Precedência: este vínculo > `ResponsavelFinanceiro` do contrato (sync legado) > titular do contrato.
  responsavelFinanceiroCustomerId String?   @map("responsavel_financeiro_customer_id")
  responsavelFinanceiroCustomer   Customer? @relation("JazigoResponsavelFinanceiro", fields: [responsavelFinanceiroCustomerId], references: [id], onDelete: SetNull)

  pagamentos Pagamento[]

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([contratoId])
  @@index([responsavelFinanceiroCustomerId])
  @@map("jazigos")
}

// =============================================================================
// 4. FINANCEIRO
// =============================================================================

/// Pagamento de manutenção, aquisição ou taxa de serviço.
///
/// Regras de negócio:
///   - jazigoId OBRIGATÓRIO para MANUTENCAO — validar na camada de serviço.
///     Nullable para AQUISICAO e TAXA_SERVICO (jazigo pode não existir ainda).
///   - contratoId: atalho direto — evita join Pagamento → Jazigo → Contrato.
///   - gavetasNaEpoca / valorNaEpoca: snapshot imutável do jazigo na data de emissão.
///     Garante rastreabilidade histórica mesmo após reajuste tarifário futuro.
///   - metodoPagamento: preenchido após confirmação do Asaas (PIX, boleto, cartão).
///   - webhookData: payload bruto do Asaas para auditoria e reprocessamento em falhas.
model Pagamento {
  id          String @id @default(uuid())
  sqlServerId Int?   @unique @map("sql_server_id")

  // Integração Asaas
  asaasId      String? @unique @map("asaas_id")   @db.VarChar(100)
  nossoNumero  String? @map("nosso_numero")        @db.VarChar(50)
  invoiceUrl   String? @map("invoice_url")         @db.Text

  // Valores
  valorTitulo  Decimal  @db.Decimal(10, 2) @map("valor_titulo")
  valorPago    Decimal? @db.Decimal(10, 2) @map("valor_pago")
  valorLiquido Decimal? @db.Decimal(10, 2) @map("valor_liquido") // valor após taxa Asaas

  // Snapshot histórico do jazigo na data de emissão
  gavetasNaEpoca Int?     @map("gavetas_na_epoca")
  valorNaEpoca   Decimal? @db.Decimal(10, 2) @map("valor_na_epoca")

  // Datas
  dataVencimento DateTime  @map("data_vencimento") @db.Date
  dataPagamento  DateTime? @map("data_pagamento")  @db.Date

  // Classificação
  status          StatusPagamento  @default(PENDENTE)
  tipo            TipoPagamento    @default(MANUTENCAO)
  metodoPagamento MetodoPagamento? @map("metodo_pagamento") // preenchido após confirmação

  // Webhook Asaas
  webhookData       Json?     @map("webhook_data")       // payload bruto para auditoria
  webhookRecebidoEm DateTime? @map("webhook_recebido_em")

  // Relações
  jazigoId   String?   @map("jazigo_id")   // obrigatório para MANUTENCAO — validar no service
  jazigo     Jazigo?   @relation(fields: [jazigoId], references: [id])

  contratoId String?   @map("contrato_id") // atalho direto
  contrato   Contrato? @relation(fields: [contratoId], references: [id])

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  notificacoes Notificacao[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([customerId])
  @@index([jazigoId])
  @@index([contratoId])
  @@index([nossoNumero])
  @@index([status])
  @@index([dataVencimento])
  @@map("pagamentos")
}

// =============================================================================
// 5. NOTIFICAÇÕES
// =============================================================================

/// Registro de cada notificação enviada ao cliente (email, WhatsApp, SMS).
///
/// Viabiliza régua de cobrança automatizada:
///   D-5  → lembrete de vencimento próximo
///   D+0  → notificação de vencimento
///   D+3  → aviso de pagamento em atraso
///   D+N  → escalonamento conforme política interna
///
/// pagamentoId nullable: notificações nem sempre estão ligadas a um pagamento
/// (ex.: confirmação de alteração cadastral aprovada).
model Notificacao {
  id          String            @id @default(uuid())
  customerId  String            @map("customer_id")
  pagamentoId String?           @map("pagamento_id")
  canal       CanalNotificacao
  status      StatusNotificacao @default(ENVIADA)
  assunto     String?           @db.VarChar(200) // usado para email
  mensagem    String            @db.Text
  erroDetalhe String?           @map("erro_detalhe") @db.Text
  enviadoEm   DateTime          @default(now()) @map("enviado_em")
  entregueEm  DateTime?         @map("entregue_em")

  customer  Customer   @relation(fields: [customerId], references: [id])
  pagamento Pagamento? @relation(fields: [pagamentoId], references: [id])

  @@index([customerId])
  @@index([pagamentoId])
  @@index([status])
  @@index([enviadoEm])
  @@map("notificacoes")
}

// =============================================================================
// 6. SOLICITAÇÕES DE ALTERAÇÃO DE CADASTRO
// =============================================================================

/// Solicitação feita pelo cliente no portal; revisada por um usuário admin.
///
/// dadoAntigo: snapshot obrigatório dos dados antes da alteração.
///             Nunca deve ser null — sem ele a revisão perde contexto de auditoria.
/// dadoNovo:   dados que o cliente deseja aplicar.
///
/// Fluxo:
///   PENDENTE → APROVADA (admin aplica os dados + preenche notaRevisao opcional)
///           → REJEITADA (admin explica o motivo em notaRevisao)
model ChangeRequest {
  id            Int             @id @default(autoincrement())
  customerId    String          @map("customer_id")
  reviewedById  String?         @map("reviewed_by_id")
  tipo          TipoAlteracao
  status        StatusAlteracao @default(PENDENTE)
  dadoAntigo    Json            @map("dado_antigo") // obrigatório — nunca null
  dadoNovo      Json            @map("dado_novo")
  justificativa String?         @db.Text
  notaRevisao   String?         @map("nota_revisao") @db.Text
  revisadoEm    DateTime?       @map("revisado_em")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt      @map("updated_at")

  customer    Customer @relation(fields: [customerId], references: [id])
  revisadoPor User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("change_requests")
}

// =============================================================================
// 7. AUDITORIA DE SINCRONIZAÇÃO (ETL SQL Server → PostgreSQL)
// =============================================================================

/// Log de cada execução do job de sincronização.
///
/// jobName discrimina qual entidade foi sincronizada:
///   "customers" | "contratos" | "jazigos" | "pagamentos"
///
/// erroDetalhes: array JSON de falhas individuais no formato:
///   [{ "entidade": "Customer", "sqlServerId": 1234, "motivo": "CPF duplicado" }]
///
/// Permite reprocessar registros específicos sem re-sincronizar a entidade inteira.
model SyncLog {
  id                   String     @id @default(uuid())
  jobName              String     @map("job_name") @db.VarChar(60)
  status               SyncStatus @default(PROCESSANDO)
  registrosNovos       Int        @default(0) @map("registros_novos")
  registrosAtualizados Int        @default(0) @map("registros_atualizados")
  falhas               Int        @default(0)
  erroDetalhes         Json?      @map("erro_detalhes") // [{ entidade, sqlServerId, motivo }]
  dataInicio           DateTime   @default(now()) @map("data_inicio")
  dataFim              DateTime?  @map("data_fim")

  @@index([jobName])
  @@index([dataInicio])
  @@map("sync_logs")
}
