// =============================================================================
// schema.prisma — Portal do Cliente DB_Fama (fama-app)
// PostgreSQL via Prisma ORM
// Combina NextAuth (portal) + AdminUser (painel) + ETL legado
// =============================================================================

generator client {
    provider        = "prisma-client"
    output          = "../generated/prisma"
    previewFeatures = ["views"]
}

datasource db {
    provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum OrigemPagamento {
    SISTEMA_INTERNO
    ASAAS
    MANUAL_ADMIN
}

enum TipoPessoa {
    FISICA
    JURIDICA
}

enum SituacaoBoleto {
    ABERTO
    LIQUIDADO
    CANCELADO
    VENCIDO
}

enum MetodoAsaas {
    BOLETO
    PIX
    CREDIT_CARD
    UNDEFINED
}

enum SyncStatus {
    RUNNING
    SUCCESS
    PARTIAL
    FAILED
}

/// Perfis de acesso do painel administrativo
enum PerfilAdmin {
    SUPER_ADMIN
    FINANCEIRO
    OPERACIONAL
    VISUALIZADOR
}

/// Ações registradas no log de auditoria
enum AcaoAuditoria {
    LOGIN
    LOGOUT
    CRIAR_CLIENTE
    ATUALIZAR_CLIENTE
    CRIAR_CONTATO
    ATUALIZAR_CONTATO
    REMOVER_CONTATO
    CRIAR_COBRANCA
    CANCELAR_COBRANCA
    CRIAR_ADMIN
    ATUALIZAR_ADMIN
    DESATIVAR_ADMIN
    SYNC_MANUAL
    EXPORTAR_RELATORIO
}

enum UserRole {
    USER
    ADMIN
}

enum BillingPaymentStatus {
    PENDING
    RECEIVED
    OVERDUE
    REFUNDED
    CANCELLED
    UNKNOWN
}

// =============================================================================
// NEXTAUTH — Portal do cliente (login CPF/CNPJ)
// =============================================================================

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? @db.Text
    access_token             String? @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? @db.Text
    session_state            String?
    refresh_token_expires_in Int?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@map("contas_oauth")
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("sessoes")
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
    @@map("tokens_verificacao")
}

/// Usuário do portal (cliente final — login via CPF/CNPJ).
model User {
    id               String           @id @default(cuid())
    name             String?
    email            String?          @unique
    emailVerified    DateTime?
    image            String?
    passwordHash     String?
    role             UserRole         @default(USER)
    asaasCustomerId  String?          @unique
    cpfCnpj          String?          @unique
    /// Liga o usuário portal ao Cessionario sincronizado do legado (CodCessionario).
    legacyExternalId Int?             @unique
    /// Proteção contra força bruta no login.
    loginAttempts    Int              @default(0)
    blockedUntil     DateTime?
    accounts         Account[]
    sessions         Session[]
    billingPayments  BillingPayment[]
    phones           ClientPhone[]
    cessionario      Cessionario?

    @@map("usuarios")
}

/// Contactos telefônicos do titular do portal (1 : N).
model ClientPhone {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    telefone    String
    observacoes String?  @db.Text
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([userId])
    @@map("telefones_cliente")
}

/// Cobrança emitida via Asaas (portal do cliente / admin).
model BillingPayment {
    id                  String               @id @default(cuid())
    userId              String
    user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    asaasPaymentId      String               @unique
    valueCents          Int
    status              BillingPaymentStatus @default(PENDING)
    description         String?
    dueDate             DateTime?
    paidAt              DateTime?
    asaasBillingType    String?              @default("PIX")
    checkoutUrl         String?              @db.Text
    boletoDigitableLine String?              @db.Text
    pixCopyPaste        String?              @db.Text
    pixQrCodeBase64     String?              @db.Text
    /// Campos preenchidos quando a cobrança origina de um Boleto legado.
    nossoNumero         String?
    parcela             String?
    numBanco            String?
    legacyBoletoId      Int?                 @unique
    externalRef         String?
    createdAt           DateTime             @default(now())
    updatedAt           DateTime             @updatedAt

    @@index([userId])
    @@index([status])
    @@index([createdAt])
    @@map("cobrancas_asaas")
}

// =============================================================================
// ADMIN USER — Painel administrativo (login e-mail + senha)
// =============================================================================

/// Usuário do painel administrativo.
/// Completamente separado dos usuários do portal (User).
model AdminUser {
    id              Int            @id @default(autoincrement())
    nome            String         @db.VarChar(100)
    email           String         @unique @db.VarChar(100)
    /// Bcrypt hash — nunca armazenar senha em texto puro.
    senhaHash       String         @db.VarChar(255)
    perfil          PerfilAdmin    @default(VISUALIZADOR)
    ativo           Boolean        @default(true)
    tentativasLogin Int            @default(0)
    bloqueadoAte    DateTime?
    ultimoLogin     DateTime?
    ultimoIp        String?        @db.VarChar(45)
    sessoes         AdminSessao[]
    auditoria       AuditoriaLog[]
    cobrancasManuais CobrancaManual[]
    createdAt       DateTime       @default(now())
    updatedAt       DateTime       @updatedAt

    @@index([email])
    @@index([perfil])
    @@map("admin_users")
}

/// Sessões JWT ativas do admin (multi-device, permite revogação).
model AdminSessao {
    id        Int       @id @default(autoincrement())
    /// JWT ID (jti claim) — identifica o token unicamente.
    tokenId   String    @unique @db.VarChar(36)
    adminId   Int
    admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
    ip        String?   @db.VarChar(45)
    userAgent String?   @db.VarChar(500)
    expiresAt DateTime
    revogado  Boolean   @default(false)
    revogarEm DateTime?
    createdAt DateTime  @default(now())

    @@index([adminId])
    @@index([expiresAt])
    @@map("admin_sessoes")
}

// =============================================================================
// AUDITORIA
// =============================================================================

/// Log imutável de todas as ações realizadas por admins.
model AuditoriaLog {
    id          Int            @id @default(autoincrement())
    acao        AcaoAuditoria
    adminId     Int?
    admin       AdminUser?     @relation(fields: [adminId], references: [id], onDelete: SetNull)
    entidade    String?        @db.VarChar(50)
    entidadeId  String?        @db.VarChar(100)
    dadosAntes  Json?
    dadosDepois Json?
    observacao  String?        @db.Text
    ip          String?        @db.VarChar(45)
    criadoEm   DateTime       @default(now())

    @@index([adminId])
    @@index([acao])
    @@index([entidade, entidadeId])
    @@index([criadoEm])
    @@map("auditoria_logs")
}

// =============================================================================
// COBRANÇA MANUAL — Criada pelo admin sem origem no SQL Server
// =============================================================================

model CobrancaManual {
    id                  Int             @id @default(autoincrement())
    descricao           String          @db.VarChar(200)
    valor               Decimal         @db.Decimal(18, 2)
    dataVencimento      DateTime
    metodo              MetodoAsaas     @default(PIX)
    situacao            SituacaoBoleto  @default(ABERTO)
    origemPagamento     OrigemPagamento @default(MANUAL_ADMIN)
    observacao          String?         @db.Text
    adminId             Int
    admin               AdminUser       @relation(fields: [adminId], references: [id])
    cessionarioId       Int
    cessionario         Cessionario     @relation(fields: [cessionarioId], references: [id])
    asaasPaymentId      String?         @unique @db.VarChar(50)
    asaasInvoiceUrl     String?
    asaasPixQrCode      String?
    asaasLinhaDigitavel String?
    dataLiquidacao      DateTime?
    valorRecebido       Decimal?        @db.Decimal(18, 2)
    createdAt           DateTime        @default(now())
    updatedAt           DateTime        @updatedAt

    @@index([cessionarioId])
    @@index([adminId])
    @@index([situacao])
    @@index([dataVencimento])
    @@map("cobrancas_manuais")
}

// =============================================================================
// ETL — Cessionários e dados legado (SQL Server → PostgreSQL)
// =============================================================================

model Cessionario {
    id                    Int                    @id @default(autoincrement())
    externalId            Int?                   @unique
    nome                  String                 @db.VarChar(80)
    cpfCnpj               String                 @db.Char(14)
    email                 String?                @db.VarChar(60)
    tipoPessoa            TipoPessoa             @default(FISICA)
    dataNascimento        DateTime?
    dataAtualizacaoLegado Float                  @default(0)
    asaasCustomerId       String?                @unique @db.VarChar(50)
    flagManual            Boolean                @default(false)
    userId                String?                @unique
    user                  User?                  @relation(fields: [userId], references: [id])
    contatos              Contato[]
    enderecos             Endereco[]
    planos                CessionarioPlano[]
    responsavel           ResponsavelFinanceiro?
    cobrancasManuais      CobrancaManual[]
    createdAt             DateTime               @default(now())
    updatedAt             DateTime               @updatedAt

    @@index([cpfCnpj])
    @@index([dataAtualizacaoLegado])
    @@map("cessionarios")
}

model Contato {
    id            Int         @id @default(autoincrement())
    externalId    Int?        @unique
    numero        String      @db.VarChar(20)
    tipo          String      @db.VarChar(20)
    observacao    String?     @db.VarChar(30)
    flagManual    Boolean     @default(false)
    cessionarioId Int
    cessionario   Cessionario @relation(fields: [cessionarioId], references: [id], onDelete: Cascade)
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    @@index([cessionarioId])
    @@map("contatos")
}

model Endereco {
    id              Int         @id @default(autoincrement())
    tipoEndereco    String      @db.VarChar(20)
    logradouro      String      @db.VarChar(100)
    complemento     String?     @db.VarChar(50)
    setor           String?     @db.VarChar(50)
    cep             String      @db.Char(10)
    cidade          String      @db.VarChar(60)
    uf              String      @db.Char(2)
    correspondencia Boolean     @default(false)
    cessionarioId   Int
    cessionario     Cessionario @relation(fields: [cessionarioId], references: [id], onDelete: Cascade)
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@unique([cessionarioId, tipoEndereco])
    @@index([cessionarioId])
    @@map("enderecos")
}

model ResponsavelFinanceiro {
    id              Int         @id @default(autoincrement())
    nome            String      @db.VarChar(80)
    cpfCnpj         String      @db.Char(14)
    email           String?     @db.VarChar(60)
    tipoPessoa      TipoPessoa  @default(FISICA)
    logradouro      String?     @db.VarChar(100)
    complemento     String?     @db.VarChar(50)
    setor           String?     @db.VarChar(50)
    cep             String?     @db.Char(10)
    cidade          String?     @db.VarChar(60)
    uf              String?     @db.Char(2)
    asaasCustomerId String?     @unique @db.VarChar(50)
    cessionarioId   Int         @unique
    cessionario     Cessionario @relation(fields: [cessionarioId], references: [id], onDelete: Cascade)
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@map("responsaveis_financeiros")
}

model CessionarioPlano {
    id                          Int         @id @default(autoincrement())
    externalId                  Int         @unique
    numPlano                    String      @db.VarChar(10)
    situacao                    String      @db.Char(1)
    diaBase                     Int?
    valor                       Decimal     @db.Decimal(18, 2)
    possuiResponsavelFinanceiro Boolean     @default(false)
    dataInclusao                DateTime?
    cessionarioId               Int
    cessionario                 Cessionario @relation(fields: [cessionarioId], references: [id], onDelete: Cascade)
    boletos                     Boleto[]
    createdAt                   DateTime    @default(now())
    updatedAt                   DateTime    @updatedAt

    @@index([cessionarioId])
    @@map("cessionarios_planos")
}

model Boleto {
    id                  Int              @id @default(autoincrement())
    externalId          Int              @unique
    nossoNumero         String           @db.VarChar(25)
    parcela             String?          @db.VarChar(10)
    numBanco            String           @db.Char(3)
    dataVencimento      DateTime
    dataLiquidacao      DateTime?
    dataCredito         DateTime?
    valorTitulo         Decimal          @db.Decimal(18, 2)
    valorRecebido       Decimal?         @db.Decimal(18, 2)
    jurosMora           Decimal          @db.Decimal(18, 2) @default(0)
    multas              Decimal          @db.Decimal(18, 2) @default(0)
    descontos           Decimal          @db.Decimal(18, 2) @default(0)
    valorComAcrescimos  Decimal?         @db.Decimal(18, 2)
    diasAtraso          Int?
    situacao            SituacaoBoleto   @default(ABERTO)
    origemPagamento     OrigemPagamento  @default(SISTEMA_INTERNO)
    metodoPreferencial  MetodoAsaas      @default(UNDEFINED)
    codFormaPagLegado   Int?
    asaasPaymentId      String?          @unique @db.VarChar(50)
    asaasInvoiceUrl     String?
    asaasPixQrCode      String?
    asaasLinhaDigitavel String?
    cessionarioPlanoId  Int
    cessionarioPlano    CessionarioPlano @relation(fields: [cessionarioPlanoId], references: [id], onDelete: Cascade)
    createdAt           DateTime         @default(now())
    updatedAt           DateTime         @updatedAt

    @@index([cessionarioPlanoId])
    @@index([situacao])
    @@index([dataVencimento])
    @@index([dataLiquidacao])
    @@map("boletos")
}

// =============================================================================
// SYNC — Auditoria de sincronização
// =============================================================================

/// Job de sincronização raw MSSQL → MssqlSyncRecord.
model SyncRun {
    id           String    @id @default(cuid())
    jobName      String
    startedAt    DateTime  @default(now())
    finishedAt   DateTime?
    status       String
    rowsRead     Int       @default(0)
    rowsWritten  Int       @default(0)
    errorMessage String?   @db.Text

    @@index([jobName])
    @@index([startedAt])
    @@map("execucoes_sincronizacao")
}

/// Registro genérico espelhado do SQL Server (chave = sourceTable + sourceKey).
model MssqlSyncRecord {
    id          String   @id @default(cuid())
    sourceTable String
    sourceKey   String
    payload     Json
    syncedAt    DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([sourceTable, sourceKey])
    @@index([sourceTable])
    @@map("registros_sync_mssql")
}

/// Log de execuções ETL tipadas com cursor delta.
model SyncLog {
    id                Int        @id @default(autoincrement())
    executadoEm       DateTime   @default(now())
    status            SyncStatus @default(RUNNING)
    curssorOleFloat   Float      @default(0)
    totalCessionarios Int        @default(0)
    totalBoletos      Int        @default(0)
    totalContatos     Int        @default(0)
    totalEnderecos    Int        @default(0)
    erros             String[]
    duracaoMs         Int?

    @@index([executadoEm])
    @@index([status])
    @@map("sync_logs")
}

// =============================================================================
// VIEWS — Dashboard (criadas via SQL raw em prisma/sql/dashboard_views.sql)
// =============================================================================

/// View com KPIs principais do dashboard.
view DashboardKpi {
    id                          Int     @unique @default(1)
    totalClientes               Int
    clientesAtivos              Int
    totalBoletos                Int
    boletosAbertos              Int
    boletosVencidos             Int
    boletosLiquidados           Int
    totalCobrancasManuais       Int
    valorTotalEmAberto          Decimal @db.Decimal(18, 2)
    valorTotalVencido           Decimal @db.Decimal(18, 2)
    valorTotalRecebidoMes       Decimal @db.Decimal(18, 2)
    valorTotalRecebidoAno       Decimal @db.Decimal(18, 2)
    valorCobrancasManuaisAberto Decimal @db.Decimal(18, 2)
    ultimoSync                  DateTime?
    statusUltimoSync            String?

    @@map("vw_dashboard_kpi")
}

/// View com inadimplência agrupada por faixa de atraso.
view DashboardInadimplencia {
    faixaAtraso   String  @unique
    totalBoletos  Int
    totalClientes Int
    valorTotal    Decimal @db.Decimal(18, 2)

    @@map("vw_dashboard_inadimplencia")
}

/// View com recebimentos agrupados por mês (últimos 12 meses).
view DashboardRecebimentoMensal {
    anoMes        String  @unique
    totalBoletos  Int
    valorRecebido Decimal @db.Decimal(18, 2)
    origemAsaas   Int
    origemSistema Int

    @@map("vw_dashboard_recebimento_mensal")
}
